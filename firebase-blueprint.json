{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile supplementary details stored in Firestore",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID matching Auth UID" },
        "email": { "type": "string", "format": "email", "description": "Verified user email address" },
        "fullName": { "type": "string", "description": "Full name of the user" },
        "role": { "type": "string", "enum": ["citizen", "volunteer", "authority"], "description": "System role determining access rights" },
        "phone": { "type": "string", "description": "Optional contact number" },
        "country": { "type": "string", "description": "Country of jurisdiction" },
        "state": { "type": "string", "description": "State of jurisdiction" },
        "district": { "type": "string", "description": "District/Ward of jurisdiction" },
        "area": { "type": "string", "description": "Specific neighborhood/area assigned" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account registration timestamp" }
      },
      "required": ["uid", "email", "fullName", "role", "createdAt"]
    },
    "Complaint": {
      "title": "Complaint",
      "description": "Civic issue/complaint reported by a citizen",
      "type": "object",
      "properties": {
        "issueType": { "type": "string", "description": "Category of the civic issue" },
        "customIssueType": { "type": "string", "description": "Custom category if Others is selected" },
        "description": { "type": "string", "description": "Detailed description of the issue" },
        "severity": { "type": "string", "enum": ["Low", "Medium", "Critical"], "description": "Current severity level of the issue" },
        "userSeverity": { "type": "string", "enum": ["Low", "Medium", "Critical"], "description": "Severity assigned/overridden by the citizen" },
        "aiSeverity": { "type": "string", "enum": ["Low", "Medium", "Critical"], "description": "Severity determined by AI model" },
        "aiSummary": { "type": "string", "description": "Short summary generated by AI" },
        "recommendedDepartment": { "type": "string", "description": "Recommended municipal department" },
        "images": { "type": "array", "description": "Base64 encoded upload images or media URLs" },
        "coordinates": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "address": { "type": "string", "description": "Physical address determined by location selection" },
        "landmark": { "type": "string", "description": "Nearby landmark specified by the citizen" },
        "citizenName": { "type": "string", "description": "Name of citizen who logged the complaint" },
        "citizenEmail": { "type": "string", "description": "Email of citizen who logged the complaint" },
        "citizenUid": { "type": "string", "description": "Auth UID of citizen who logged the complaint" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" },
        "date": { "type": "string", "description": "Creation date (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Creation time (HH:MM)" },
        "status": { "type": "string", "enum": ["Reported", "Volunteer Verification In Progress", "Authority Verified", "Repair In Progress", "Resolved", "Rejected"], "description": "Resolution status lifecycle" },
        "assignedVolunteerId": { "type": "string", "description": "Volunteer UID assigned to physical verification" },
        "assignedVolunteerName": { "type": "string", "description": "Name of volunteer assigned to physical verification" },
        "volunteerVerificationDate": { "type": "string", "format": "date-time", "description": "Timestamp when physical verification occurred" },
        "volunteerNotes": { "type": "string", "description": "On-site verification notes recorded by volunteer" },
        "volunteerImages": { "type": "array", "description": "On-site images uploaded by volunteer" },
        "isGenuine": { "type": "boolean", "description": "On-site verification mark of validity" },
        "authorityNotes": { "type": "string", "description": "Board administrative notes" },
        "authorityApprovalDate": { "type": "string", "format": "date-time", "description": "Timestamp when board approved the action" },
        "rejectionReason": { "type": "string", "description": "Reason given if complaint is rejected" },
        "assignedDepartment": { "type": "string", "description": "Department assigned to carry out repair works" },
        "assignedWorkers": { "type": "string", "description": "Team designation/workers assigned" },
        "expectedCompletionDate": { "type": "string", "description": "Expected repair completion date" },
        "repairStatusUpdates": { "type": "array", "description": "Progress logs added during work execution" },
        "completionNotes": { "type": "string", "description": "Sign-off notes added on repair resolution" },
        "completionImages": { "type": "array", "description": "Resolution evidence images" },
        "resolvedAt": { "type": "string", "format": "date-time", "description": "Timestamp of full resolution" }
      },
      "required": ["issueType", "description", "severity", "userSeverity", "aiSeverity", "images", "coordinates", "address", "citizenName", "citizenEmail", "citizenUid", "createdAt", "date", "time", "status"]
    },
    "FeedbackSubmission": {
      "title": "FeedbackSubmission",
      "description": "Citizen feedback, appreciation, or suggestions",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique feedback ID" },
        "type": { "type": "string", "enum": ["Feedback", "Suggestion", "Appreciation"], "description": "Category of feedback" },
        "content": { "type": "string", "description": "Detailed text content of feedback" },
        "citizenName": { "type": "string", "description": "Citizen author name" },
        "citizenEmail": { "type": "string", "description": "Citizen author email" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Submission timestamp" }
      },
      "required": ["type", "content", "citizenName", "citizenEmail", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "UserProfile",
      "description": "User details for Citizen, Volunteer, and Authority accounts"
    },
    "complaints/{complaintId}": {
      "schema": "Complaint",
      "description": "Municipal and public complaints database"
    },
    "feedbacks/{feedbackId}": {
      "schema": "FeedbackSubmission",
      "description": "Public feedback and suggestions collection"
    }
  }
}
